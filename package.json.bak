{
  "name": "billing-system",
  "version": "1.0.0",
  "description": "Complete Billing System with React Frontend and Node.js Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client": "cd client && npm start",
    "server": "nodemon server.js",
    "build": "cd client && npm run build",
    "heroku-postbuild": "npm run build"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.22.1",
    "express-rate-limit": "^6.8.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "mysql": "^2.18.1",
    "mysql2": "^3.6.0",
    "nodemailer": "^6.9.4",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react-qr-reader": "^2.2.1",
    "react-qr-scanner": "^1.0.0-alpha.11"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "billing",
    "pos",
    "react",
    "nodejs",
    "mysql"
  ],
  "author": "Dharsini",
  "license": "MIT"
  "proxy": "http://localhost:5000"
}
